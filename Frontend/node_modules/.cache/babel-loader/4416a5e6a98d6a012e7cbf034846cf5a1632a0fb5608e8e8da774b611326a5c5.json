ap":{"version":3,"names":["React","jsxDEV","_jsxDEV","Fragment","_Fragment","InfoTextSearch","children","fileName","_jsxFileName","lineNumber","columnNumber","href","_c","$RefreshReg$"],"sources":["C:/Users/egors/OneDrive/Desktop/ORIS_JS/oris_verstrka_react/src/components/InfoTextSearch.jsx"],"sourcesContent":["import React from 'react';\r\n\r\nconst InfoTextSearch = () => {\r\n  return (\r\n    <>\r\n      <section>\r\n                    <strong>\r\n                      Горячие туры – Найдите идеальное путешествие с нами!\r\n                    </strong>\r\n                    <p>\r\n                      Ищете выгодные предложения для незабываемого отпуска? На\r\n                      нашем сайте вы найдете <strong>горячие туры</strong> по\r\n                      самым популярным направлениям! Мы предлагаем удобную\r\n                      систему поиска туров, которая позволяет быстро подобрать\r\n                      лучший вариант по цене и качеству.\r\n                    </p>\r\n                  </section>\r\n                  <section>\r\n                    <strong>Что такое горячие туры?</strong>\r\n                    <p>\r\n                      <strong>Горячие туры</strong> – это отличная возможность\r\n                      отправиться в путешествие по сниженной стоимости. Такие\r\n                      туры появляются благодаря свободным местам на рейсах и в\r\n                      отелях, что позволяет существенно сэкономить.\r\n                      Воспользовавшись нашим сервисом, вы можете найти горящие\r\n                      предложения за считанные минуты.\r\n                    </p>\r\n                  </section>\r\n                  <section>\r\n                    <strong>Почему выбирают нас?</strong>\r\n                    <ul>\r\n                      <li>\r\n                        <strong>Широкий выбор направлений.</strong> У нас\r\n                        представлены <strong>горящие туры</strong> в Турцию,\r\n                        Египет, Таиланд, ОАЭ и другие страны. Любите отдых в\r\n                        России? Выбирайте туры в Сочи, Крым, Санкт-Петербург, на\r\n                        Байкал и Алтай.\r\n                      </li>\r\n                      <li>\r\n                        <strong>Проверенные туроператоры.</strong> Мы работаем\r\n                        только с надежными партнерами, чтобы гарантировать вам\r\n                        безопасность и комфорт.\r\n                      </li>\r\n                      <li>\r\n                        <strong>Удобство и простота.</strong> Все туры включают\r\n                        перелет, проживание, трансфер, а также страховку. Вам\r\n                        остается только выбрать направление и наслаждаться\r\n                        отдыхом.\r\n                      </li>\r\n                    </ul>\r\n                  </section>\r\n                  <section>\r\n                    <strong>Дополнительные услуги для путешественников</strong>\r\n                    <p>\r\n                      На нашем сайте вы можете не только найти{\" \"}\r\n                      <strong>горячие туры</strong>, но и воспользоваться\r\n                      другими услугами:\r\n                    </p>\r\n                    <ul>\r\n                      <li>\r\n                        <a href=\"#\">Купить авиабилеты</a> и{\" \"}\r\n                        <a href=\"#\">забронировать отели</a>.\r\n                      </li>\r\n                      <li>\r\n                        <a href=\"#\">Оформить страховой полис для путешествия</a>\r\n                        .\r\n                      </li>\r\n                      <li>\r\n                        Получить консультацию от профессиональных менеджеров,\r\n                        которые помогут с выбором тура и предложат выгодные\r\n                        условия.\r\n                      </li>\r\n                      <li>\r\n                        <a href=\"#\">Заказ персонального трансфера</a>.\r\n                      </li>\r\n                      <li>\r\n                        <a href=\"#\">\r\n                          Получите бесплатную eSIM с 250 МБ интернета по\r\n                          промокоду HOTTTBG\r\n                        </a>\r\n                        .\r\n                      </li>\r\n                    </ul>\r\n                  </section>\r\n                  <section>\r\n                    <strong>Как найти идеальный тур?</strong>\r\n                    <p>Наша система поиска туров предлагает:</p>\r\n                    <ul>\r\n                      <li>\r\n                        Фильтрацию по дате вылета, продолжительности\r\n                        путешествия, стоимости и типу отдыха.\r\n                      </li>\r\n                      <li>\r\n                        Подробные описания отелей с фотографиями, отзывами и\r\n                        рейтингами.\r\n                      </li>\r\n                      <li>Быстрое бронирование и безопасную оплату.</li>\r\n                    </ul>\r\n                  </section>\r\n                  <section>\r\n                    <strong>Популярные направления горячих туров</strong>\r\n                    <p>\r\n                      Среди наших клиентов пользуются популярностью следующие\r\n                      направления:\r\n                    </p>\r\n                    <ul>\r\n                      <li>\r\n                        <strong>Зарубежный отдых:</strong> Турция, Египет,\r\n                        Таиланд, ОАЭ.\r\n                      </li>\r\n                      <li>\r\n                        <strong>Россия:</strong> Сочи, Крым, Санкт-Петербург,\r\n                        Казань, Байкал, Алтай.\r\n                      </li>\r\n                    </ul>\r\n                    <p>\r\n                      Мы постоянно обновляем актуальные предложения, чтобы вы\r\n                      всегда могли выбрать самое выгодное путешествие.\r\n                    </p>\r\n                  </section>\r\n                  <section>\r\n                    <strong>Ваш отдых начинается здесь!</strong>\r\n                    <p>\r\n                      Не тратьте время на долгие поиски. Забронируйте{\" \"}\r\n                      <strong>горячий тур</strong> онлайн прямо сейчас и\r\n                      отправляйтесь в путешествие мечты. С нами ваш отпуск\r\n                      станет незабываемым!\r\n                    </p>\r\n                    <p>\r\n                      <strong>Ищите выгодные предложения?</strong> Используйте\r\n                      наш поиск, чтобы найти и забронировать{\" \"}\r\n                      <strong>горячий тур</strong> по лучшим направлениям.\r\n                      Путешествуйте удобно, быстро и безопасно!\r\n                    </p>\r\n                  </section>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default InfoTextSearch;"],"mappings":";AAAA,OAAOA,KAAK,MAAM,OAAO;AAAC,SAAAC,MAAA,IAAAC,OAAA,EAAAC,QAAA,IAAAC,SAAA;AAE1B,MAAMC,cAAc,GAAGA,CAAA,KAAM;EAC3B,oBACEH,OAAA,CAAAE,SAAA;IAAAE,QAAA,gBACEJ,OAAA;MAAAI,QAAA,gBACcJ,OAAA;QAAAI,QAAA,EAAQ;MAER;QAAAC,QAAA,EAAAC,YAAA;QAAAC,UAAA;QAAAC,YAAA;MAAA,OAAQ,CAAC,eACTR,OAAA;QAAAI,QAAA,GAAG,saAEsB,eAAAJ,OAAA;UAAAI,QAAA,EAAQ;QAAY;UAAAC,QAAA,EAAAC,YAAA;UAAAC,UAAA;UAAAC,YAAA;QAAA,OAAQ,CAAC,ywBAItD;MAAA;QAAAH,QAAA,EAAAC,YAAA;QAAAC,UAAA;QAAAC,YAAA;MAAA,OAAG,CAAC;IAAA;MAAAH,QAAA,EAAAC,YAAA;MAAAC,UAAA;MAAAC,YAAA;IAAA,OACG,CAAC,eACVR,OAAA;MAAAI,QAAA,gBACEJ,OAAA;QAAAI,QAAA,EAAQ;MAAuB;QAAAC,QAAA,EAAAC,YAAA;QAAAC,UAAA;QAAAC,YAAA;MAAA,OAAQ,CAAC,eACxCR,OAAA;QAAAI,QAAA,gBACEJ,OAAA;UAAAI,QAAA,EAAQ;QAAY;UAAAC,QAAA,EAAAC,YAAA;UAAAC,UAAA;UAAAC,YAAA;QAAA,OAAQ,CAAC,+6CAM/B;MAAA;QAAAH,QAAA,EAAAC,YAAA;QAAAC,UAAA;QAAAC,YAAA;MAAA,OAAG,CAAC;IAAA;MAAAH,QAAA,EAAAC,YAAA;MAAAC,UAAA;MAAAC,YAAA;IAAA,OACG,CAAC,eACVR,OAAA;MAAAI,QAAA,gBACEJ,OAAA;QAAAI,QAAA,EAAQ;MAAoB;QAAAC,QAAA,EAAAC,YAAA;QAAAC,UAAA;QAAAC,YAAA;MAAA,OAAQ,CAAC,eACrCR,OAAA;QAAAI,QAAA,gBACEJ,OAAA;UAA