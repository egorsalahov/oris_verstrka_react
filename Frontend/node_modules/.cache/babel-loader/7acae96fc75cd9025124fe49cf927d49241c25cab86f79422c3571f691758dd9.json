0442\\u0443\\u0440\\u044B\\xBB\"\n            }, void 0, false, {\n              fileName: _jsxFileName,\n              lineNumber: 104,\n              columnNumber: 19\n            }, this), \" \\u0432 \\u041C\\u043E\\u0441\\u043A\\u0432\\u0435, \\u0432\\u044B \\u043C\\u043E\\u0436\\u0435\\u0442\\u0435 \\u0431\\u044B\\u0442\\u044C \\u0443\\u0432\\u0435\\u0440\\u0435\\u043D\\u044B \\u0432 \\u0440\\u0435\\u0437\\u0443\\u043B\\u044C\\u0442\\u0430\\u0442\\u0435. \\u041D\\u0430\\u0448\\u0430 \\u0440\\u0430\\u0431\\u043E\\u0442\\u0430 \\u2013 \\u043F\\u043E\\u043C\\u043E\\u0447\\u044C \\u0432\\u0430\\u043C \\u043F\\u043E\\u0434\\u043E\\u0431\\u0440\\u0430\\u0442\\u044C \\u0438 \\u043A\\u0443\\u043F\\u0438\\u0442\\u044C \\u0442\\u0443\\u0440 \\u043E\\u043D\\u043B\\u0430\\u0439\\u043D \\u0438\\u043B\\u0438 \\u0432 \\u043E\\u0444\\u0438\\u0441\\u0435 \\u043B\\u0443\\u0447\\u0448\\u0435 \\u0432\\u0441\\u0435\\u0445, \\u043E \\u043A\\u043E\\u043C \\u0432\\u044B \\u0441\\u043B\\u044B\\u0448\\u0430\\u043B\\u0438!\"]\n          }, void 0, true, {\n            fileName: _jsxFileName,\n            lineNumber: 103,\n            columnNumber: 9\n          }, this)]\n        }, void 0, true, {\n          fileName: _jsxFileName,\n          lineNumber: 8,\n          columnNumber: 7\n        }, this)\n      }, void 0, false, {\n        fileName: _jsxFileName,\n        lineNumber: 7,\n        columnNumber: 5\n      }, this)\n    }, void 0, false, {\n      fileName: _jsxFileName,\n      lineNumber: 6,\n      columnNumber: 7\n    }, this)\n  }, void 0, false);\n};\n_c = AboutCompany;\nexport default AboutCompany;\nvar _c;\n$RefreshReg$(_c, \"AboutCompany\");","map":{"version":3,"names":["React","jsxDEV","_jsxDEV","Fragment","_Fragment","AboutCompany","children","className","fileName","_jsxFileName","lineNumber","columnNumber","href","_c","$RefreshReg$"],"sources":["C:/Users/egors/OneDrive/Desktop/ORIS_JS/oris_verstrka_react/src/components/AboutCompany.jsx"],"sourcesContent":["import React from 'react';\r\n\r\nconst AboutCompany = () => {\r\n  return (\r\n    <>\r\n      <div className=\"index_content\">\r\n    <div className=\"container\">\r\n      <section>\r\n        <p className=\"title_pink\">\r\n          СЕТЬ ТУРИСТИЧЕСКИХ АГЕНТСТВ «ГОРЯЧИЕ ТУРЫ»:\r\n        </p>\r\n        <p className=\"title_black\">ПОДОБРАТЬ И КУПИТЬ ТУР ОНЛАЙН ИЛИ В ОФИСЕ</p>\r\n        <p>&nbsp;</p>\r\n        <section className=\"content_link\">\r\n          <p>\r\n            Вы можете купить горячие туры онлайн, воспользовавшись\r\n            <a href=\"#\">\r\n              удобной системой поиска туров с подробным описанием отелей\r\n            </a>\r\n            , размещенных на нашем сайте. Мы сотрудничаем только с проверенными\r\n            туроператорами, репутация которых подтверждена многолетним опытом\r\n            работы.\r\n          </p>\r\n        </section>\r\n        <section className=\"content_link\">\r\n          <strong>О компании</strong>\r\n          <p>\r\n            Компания «Горячие туры» работает с 2002 года, предлагая клиентам\r\n            широкий выбор направлений для отдыха по всему миру и внутри России.\r\n            Популярные горячие туры включают путешествия в Турцию, Египет,\r\n            Таиланд, ОАЭ. <br />\r\n            Для любителей отдыха в России доступны туры в Сочи, Крым, Казань,\r\n            Санкт-Петербург, на Байкал и Алтай. Наша цель — сделать путешествия\r\n            доступными, комфортными и запоминающимися.\r\n          </p>\r\n        </section>\r\n        <section className=\"content_link\">\r\n          <strong>Преимущества</strong>\r\n          <p>\r\n            Оплата в режиме онлайн проходит через защищенное соединение,\r\n            обеспечивая безопасность перевода денежных средств. Если вы\r\n            предпочитаете личное общение, наши профессиональные консультанты с\r\n            радостью примут вас в офисе, ответят на все вопросы и помогут\r\n            подобрать идеальный тур.\r\n            <br />\r\n            Наши <a href=\"#\">турагентства расположены в вашем городе</a>, чтобы\r\n            помочь вам выбрать маршрут, рассказать о лучших отелях и\r\n            предложениях, а также предоставить полную информацию о преимуществах\r\n            каждого варианта. Мы предлагаем не только международные горячие\r\n            туры, но и путешествия по России.\r\n          </p>\r\n        </section>\r\n        <section className=\"content_link\">\r\n          <strong>Дополнительные услуги</strong>\r\n          <p>\r\n            Кроме того, у нас вы можете приобрести страховой полис для\r\n            путешествий, который обеспечит вашу безопасность в поездке, а также\r\n            забронировать авиабилеты и <a href=\"#\">отели отдельно от тура</a>.\r\n            Это особенно удобно для тех, кто планирует путешествие\r\n            самостоятельно.\r\n          </p>\r\n        </section>\r\n        <section className=\"content_link\">\r\n          <strong>Удобство и безопасность</strong>\r\n          <p>\r\n            Мы принимаем оплату как банковскими картами, так и наличными\r\n            средствами. Также сотрудники помогут с оформлением страхового\r\n            пакета, если это потребуется. Для вашего удобства наши офисы\r\n            работают не только в будние дни, но и в выходные.\r\n          </p>\r\n          <p>\r\n            Забронировать и купить тур можно за считанные минуты. Мы сделали\r\n            процесс максимально простым, быстрым и удобным, чтобы ваша мечта о\r\n            путешествии стала реальностью уже сегодня!\r\n          </p>\r\n        </section>\r\n        <section className=\"content_link\">\r\n          <strong>Выгодные предложения</strong>\r\n          <p>\r\n            Ищете выгодные предложения? У нас всегда актуальные горячие туры по\r\n            популярным направлениям: Турция, Египет, Таиланд, ОАЭ, Греция,\r\n            Испания и другие. Найдите свой идеальный отдых с «Горячими турами»!\r\n          </p>\r\n        </section>\r\n        <div className=\"card card_index_content\">\r\n          <p className=\"title_pink\">КАК НАЙТИ И КУПИТЬ ТУР?</p>\r\n          <ul className=\"content_link\">\r\n            <li>\r\n              Ищите недорогие путевки и горящие туры? Вам в раздел «Горящие\r\n              туры»\r\n            </li>\r\n            <li>\r\n              Узнать где находится ближайшее турагентство можно в разделе{\" \"}\r\n              <a href=\"#\">«Офисы продаж»</a>\r\n            </li>\r\n            <li>\r\n              Не можете выбрать куда поехать? Раздел{\" \"}\r\n              <a href=\"#\">«Подбор тура»</a> поможет найти тур из Москвы онлайн и\r\n              забронировать его\r\n            </li>\r\n          </ul>\r\n        </div>\r\n        <p className=\"content_link\">\r\n          Выбирая <a href=\"#\">агентство «Горячие туры»</a> в Москве, вы можете\r\n          быть уверены в результате. Наша работа – помочь вам подобрать и купить\r\n          тур онлайн или в офисе лучше всех, о ком вы слышали!\r\n        </p>\r\n      </section>\r\n    </div>\r\n  </div>\r\n    </>\r\n  );\r\n};\r\n\r\nexport default AboutCompany;"],"mappings":";AAAA,OAAOA,KAAK,MAAM,OAAO;AAAC,SAAAC,MAAA,IAAAC,OAAA,EAAAC,QAAA,IAAAC,SAAA;AAE1B,MAAMC,YAAY,GAAGA,CAAA,KAAM;EACzB,oBACEH,OAAA,CAAAE,SAAA;IAAAE,QAAA,eACEJ,OAAA;MAAKK,SAAS,EAAC,eAAe;MAAAD,QAAA,eAChCJ,OAAA;QAAKK,SAAS,EAAC,WAAW;QAAAD,QAAA,eACxBJ,OAAA;UAAAI,QAAA,gBACEJ,OAAA;YAAGK,SAAS,EAAC,YAAY;YAAAD,QAAA,EAAC;UAE1B;YAAAE,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OAAG,CAAC,eACJT,OAAA;YAAGK,SAAS,EAAC,aAAa;YAAAD,QAAA,EAAC;UAAyC;YAAAE,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OAAG,CAAC,eACxET,OAAA;YAAAI,QAAA,EAAG;UAAM;YAAAE,QAAA,EAAAC,YAAA;YAAAC,UAAA;YAAAC,YAAA;UAAA,OAAG,CAAC,eACbT,OAAA;YAASK,SAAS,EAAC,cAAc;YAAAD,QAAA,eAC/BJ,OAAA;cAAAI,QAAA,GAAG,mSAED,eAAAJ,OAAA;gBAAGU,IAAI,EAAC,GAAG;gBAAAN,QAAA,EAAC;cAEZ;gBAAAE,QAAA,EAAAC,YAAA;gBAAAC,UAAA;gBAAAC,YAAA;cAAA,OAAG,CAAC,8uBAIN;YAAA;cAAAH,QAAA,EAAAC,YAAA;cAAAC,